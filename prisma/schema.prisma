// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  AGENT
}

enum ColumnDataType {
  TEXT
  NUMBER
  DATE_ISO
}

enum ChartType {
  BAR
  LINE
  PIE
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(USER)
  csvUploads CsvUpload[]

  @@map("user")
}

model CsvUpload {
  id        String          @id @default(uuid())
  fileName  String
  data      Json
  createdAt DateTime        @default(now())
  userId    String
  charts    ChartMetaData[]
  user      User            @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("csv_upload")
}

model ChartMetaData {
  id           String        @id @default(uuid())
  type         ChartType
  xAxis        String
  yAxis        String
  name         String
  csvUpload    CsvUpload     @relation(fields: [csvUploadId], references: [id])
  csvUploadId  String
  Chat         ChatMessage[]
  createdAt    DateTime      @default(now())
  openAiFileId String?

  @@index([csvUploadId, createdAt])
  @@map("chart_meta_data")
}

model ChatMessage {
  id              String        @id @default(uuid())
  content         String
  role            Role
  chartMetaData   ChartMetaData @relation(fields: [chartMetaDataId], references: [id])
  chartMetaDataId String
  createdAt       DateTime      @default(now())

  @@index([chartMetaDataId, createdAt])
  @@map("chat_message")
}
